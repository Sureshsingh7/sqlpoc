
################################################################################
# Terraform (core)
################################################################################

# Local .terraform directories (providers, modules, cache)
**/.terraform/

# Terraform state (NEVER commit)
*.tfstate
*.tfstate.*
terraform.tfstate.d/
.terraform.tfstate.lock.info
*.lock.hcl

# Terraform plan files (often contain sensitive diffs/values)
*.tfplan
*tfplan*

# Crash logs
crash.log
crash.*.log

# CLI config files (local user-specific)
.terraformrc
terraform.rc

# Override files (local-only tweaks)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

################################################################################
# Terraform variables (usually contain secrets)
################################################################################

# Ignore all tfvars by default
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# But allow example/stub files to be committed
!*.tfvars.example
!*.tfvars.json.example
!*.auto.tfvars.example
!*.auto.tfvars.json.example

################################################################################
# Repo-specific local env outputs (generated)
################################################################################

# Local environment files you generate (do not commit)
**/output.local.env.ps1
**/output.local.env
**/*.env
**/*.env.ps1
**/.env
**/.env.*

# Allow templates only (commit these)
!**/output.local.env.ps1.example
!**/*.env.example

################################################################################
# Editor/IDE
################################################################################

.vscode/
.idea/
*.code-workspace

################################################################################
# OS junk (Windows/Mac)
################################################################################

Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

################################################################################
# Logs / temp
################################################################################

*.log
*.tmp

# Sensitive key files
key.txt
**/key.txt
